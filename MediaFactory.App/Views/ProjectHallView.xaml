<UserControl x:Class="Views.ProjectHallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MediaFactory.Localization">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding CurrentPageTitle}"
                       Style="{StaticResource SectionTitleStyle}"
                       FontSize="32" />
            <TextBlock Margin="0,6,0,0"
                       Text="{Binding CurrentPageDescription}"
                       Style="{StaticResource BodyTextStyle}"
                       FontSize="13" />
        </StackPanel>

        <WrapPanel Grid.Row="2">
            <Button MinWidth="98"
                    Height="38"
                    Margin="0,0,10,10"
                    Content="{loc:Loc ProjectHall.Filter.All}"
                    Click="AllFilterButton_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource FilterChipButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAllFilter}" Value="True">
                                <Setter Property="Background" Value="#DBEAFE" />
                                <Setter Property="BorderBrush" Value="#60A5FA" />
                                <Setter Property="Foreground" Value="#1D4ED8" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button MinWidth="98"
                    Height="38"
                    Margin="0,0,10,10"
                    Content="{loc:Loc ProjectHall.Filter.Planning}"
                    Click="PlanningFilterButton_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource FilterChipButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPlanningFilter}" Value="True">
                                <Setter Property="Background" Value="#DCFCE7" />
                                <Setter Property="BorderBrush" Value="#4ADE80" />
                                <Setter Property="Foreground" Value="#15803D" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button MinWidth="98"
                    Height="38"
                    Margin="0,0,10,10"
                    Content="{loc:Loc ProjectHall.Filter.Rendering}"
                    Click="RenderingFilterButton_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource FilterChipButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRenderingFilter}" Value="True">
                                <Setter Property="Background" Value="#FFEDD5" />
                                <Setter Property="BorderBrush" Value="#FB923C" />
                                <Setter Property="Foreground" Value="#C2410C" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button MinWidth="98"
                    Height="38"
                    Margin="0,0,10,10"
                    Content="{loc:Loc ProjectHall.Filter.Ready}"
                    Click="ReadyFilterButton_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource FilterChipButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsReadyFilter}" Value="True">
                                <Setter Property="Background" Value="#EDE9FE" />
                                <Setter Property="BorderBrush" Value="#A78BFA" />
                                <Setter Property="Foreground" Value="#6D28D9" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button MinWidth="118"
                    Height="38"
                    Margin="0,0,10,10"
                    Content="{loc:Loc ProjectHall.Filter.Failed}"
                    Click="FailedFilterButton_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource FilterChipButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFailedFilter}" Value="True">
                                <Setter Property="Background" Value="#FEF2F2" />
                                <Setter Property="BorderBrush" Value="#FCA5A5" />
                                <Setter Property="Foreground" Value="#DC2626" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button MinWidth="98"
                    Height="38"
                    Margin="0,0,10,10"
                    Content="{loc:Loc ProjectHall.Filter.Completed}"
                    Click="CompletedFilterButton_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource FilterChipButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCompletedFilter}" Value="True">
                                <Setter Property="Background" Value="#ECFDF5" />
                                <Setter Property="BorderBrush" Value="#34D399" />
                                <Setter Property="Foreground" Value="#059669" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </WrapPanel>

        <Grid Grid.Row="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredProjects}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="304"
                                    Height="224"
                                    Margin="0,0,14,14"
                                    Style="{StaticResource SoftCardStyle}"
                                    Padding="12"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="ProjectCard_MouseLeftButtonUp">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="124" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Border Background="#EAF0F8" CornerRadius="12" ClipToBounds="True">
                                            <Image Source="{Binding ProjectCover}" Stretch="UniformToFill" />
                                        </Border>
                                        <TextBlock x:Name="CoverPlaceholder"
                                                   Text="{loc:Loc ProjectHall.NoCover}"
                                                   Foreground="#94A3B8"
                                                   FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                        <Border HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Padding="10,4"
                                                Background="{Binding StageBrush}"
                                                CornerRadius="11"
                                                Margin="8">
                                            <TextBlock Text="{Binding LocalizedStageText}"
                                                       Foreground="White"
                                                       FontSize="10"
                                                       FontFamily="Microsoft YaHei UI Semibold" />
                                        </Border>
                                    </Grid>

                                    <TextBlock Grid.Row="2"
                                               Text="{Binding ProjectName}"
                                               Style="{StaticResource SectionTitleStyle}"
                                               FontSize="17"
                                               TextTrimming="CharacterEllipsis" />

                                    <Grid Grid.Row="4">
                                        <Button HorizontalAlignment="Right"
                                                Width="96"
                                                Height="36"
                                                Padding="12,6"
                                                FontSize="13"
                                                Content="{loc:Loc ProjectHall.RetryFailed}"
                                                Tag="{Binding}"
                                                Visibility="{Binding FailureVisibility}"
                                                Style="{StaticResource SecondaryActionButtonStyle}"
                                                Click="RetryFailedButton_Click" />
                                    </Grid>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding HasProjectCover}" Value="True">
                                    <Setter TargetName="CoverPlaceholder" Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
