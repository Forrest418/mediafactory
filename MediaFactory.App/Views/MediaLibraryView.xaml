<UserControl x:Class="Views.MediaLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MediaFactory.Localization">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding CurrentPageTitle}"
                       Style="{StaticResource SectionTitleStyle}"
                       FontSize="34" />
            <TextBlock Margin="0,8,0,0"
                       Text="{Binding CurrentPageDescription}"
                       Style="{StaticResource BodyTextStyle}"
                       FontSize="14" />
        </StackPanel>

        <DockPanel Grid.Row="2" LastChildFill="False">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="{loc:Loc Media.Filter.All}" Click="AllMediaFilterButton_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterChipButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAllMediaFilter}" Value="True">
                                    <Setter Property="Background" Value="#DBEAFE" />
                                    <Setter Property="BorderBrush" Value="#60A5FA" />
                                    <Setter Property="Foreground" Value="#1D4ED8" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{loc:Loc Media.Filter.Source}" Click="SourceMediaFilterButton_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterChipButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSourceMediaFilter}" Value="True">
                                    <Setter Property="Background" Value="#E0F2FE" />
                                    <Setter Property="BorderBrush" Value="#38BDF8" />
                                    <Setter Property="Foreground" Value="#0369A1" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{loc:Loc Media.Filter.Generated}" Click="GeneratedMediaFilterButton_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterChipButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGeneratedMediaFilter}" Value="True">
                                    <Setter Property="Background" Value="#DCFCE7" />
                                    <Setter Property="BorderBrush" Value="#4ADE80" />
                                    <Setter Property="Foreground" Value="#15803D" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{loc:Loc Media.Filter.Failed}" Click="FailedMediaFilterButton_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterChipButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFailedMediaFilter}" Value="True">
                                    <Setter Property="Background" Value="#FEF2F2" />
                                    <Setter Property="BorderBrush" Value="#FCA5A5" />
                                    <Setter Property="Foreground" Value="#DC2626" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Width="120"
                        Margin="0,0,12,0"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Content="{loc:Loc Media.Action.OpenProject}"
                        IsEnabled="{Binding HasSelectedMediaLibraryItem}"
                        Click="OpenMediaProjectButton_Click" />
                <Button Width="120"
                        Margin="0,0,12,0"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Content="{loc:Loc Media.Action.OpenFile}"
                        IsEnabled="{Binding HasSelectedMediaLibraryItem}"
                        Click="OpenMediaFileButton_Click" />
                <Button Width="120"
                        Margin="0,0,12,0"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Content="{loc:Loc Media.Action.Download}"
                        IsEnabled="{Binding HasSelectedMediaLibraryItem}"
                        Click="DownloadMediaButton_Click" />
                <Button Width="120"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Content="{loc:Loc Media.Action.Preview}"
                        IsEnabled="{Binding HasSelectedMediaLibraryItem}"
                        Click="PreviewMediaButton_Click" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="4">
            <Border Style="{StaticResource ShellCardStyle}">
                <Grid>
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#94A3B8"
                               FontSize="14"
                               Text="{loc:Loc Media.Empty}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasFilteredMediaLibraryItems}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ListBox ItemsSource="{Binding FilteredMediaLibraryItems}"
                             SelectedItem="{Binding SelectedMediaLibraryItem, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource GalleryItemStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.Style>
                            <Style TargetType="ListBox">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasFilteredMediaLibraryItems}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="ThumbCard"
                                        Width="208"
                                        Height="188"
                                        Background="White"
                                        BorderBrush="#D7DFEB"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="128" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="30" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Border Background="#EEF2F7"
                                                    CornerRadius="12"
                                                    ClipToBounds="True"
                                                    Cursor="Hand"
                                                    Tag="{Binding}"
                                                    MouseLeftButtonUp="PreviewImageMouseLeftButtonUp">
                                                <Image Source="{Binding Preview}" Stretch="UniformToFill" />
                                            </Border>

                                            <TextBlock x:Name="ThumbPlaceholder"
                                                       Text="{loc:Loc Media.NoPreview}"
                                                       Foreground="#94A3B8"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />

                                            <StackPanel x:Name="HoverTools"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Margin="8"
                                                        Visibility="Collapsed">
                                                <Button Width="52"
                                                        Height="28"
                                                        Margin="0,0,6,0"
                                                        Content="{loc:Loc Media.InlinePreview}"
                                                        Tag="{Binding}"
                                                        Click="PreviewMediaButtonInline_Click" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid Grid.Row="2">
                                            <TextBlock VerticalAlignment="Center"
                                                       Text="{Binding Title}"
                                                       Style="{StaticResource SectionTitleStyle}"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxHeight="30" />
                                        </Grid>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding HasPreview}" Value="True">
                                        <Setter TargetName="ThumbPlaceholder" Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                        <Setter TargetName="ThumbCard" Property="BorderBrush" Value="#3B82F6" />
                                        <Setter TargetName="ThumbCard" Property="BorderThickness" Value="2" />
                                        <Setter TargetName="ThumbCard" Property="Background" Value="#EFF6FF" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                        <Setter TargetName="HoverTools" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
