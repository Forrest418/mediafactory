<UserControl x:Class="Views.ProjectImageUploadPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MediaFactory.Localization">
    <Border Style="{StaticResource ShellCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="154" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="{loc:Loc Upload.Title}"
                               Style="{StaticResource SectionTitleStyle}"
                               FontSize="16" />
                    <TextBlock Margin="0,4,0,0"
                               Text="{loc:Loc Upload.Description}"
                               Style="{StaticResource BodyTextStyle}" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding LoadedImageCountText}"
                           Foreground="#64748B"
                           FontFamily="Microsoft YaHei UI Semibold"
                           VerticalAlignment="Top" />
            </DockPanel>

            <Border Grid.Row="2"
                    Background="#F8FAFD"
                    BorderBrush="#D1D9E6"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="12">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="UploadedItemsControl"
                                      ItemsSource="{Binding UploadedImages}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="104"
                                            Height="116"
                                            Margin="0,0,12,0"
                                            Background="White"
                                            BorderBrush="#D1D9E6"
                                            BorderThickness="1"
                                            CornerRadius="14">
                                        <Grid>
                                            <Border Margin="8,8,8,30"
                                                    Background="#EEF2F7"
                                                    CornerRadius="10"
                                                    ClipToBounds="True">
                                                <Image Source="{Binding Preview}" Stretch="UniformToFill" />
                                            </Border>
                                            <Border HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Margin="8,8,0,0"
                                                    Padding="6,2"
                                                    Background="#2563EB"
                                                    CornerRadius="9">
                                                <TextBlock Text="{Binding BadgeText}" Foreground="White" FontSize="11" />
                                            </Border>
                                            <Button Width="24"
                                                    Height="24"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="0,8,8,0"
                                                    Padding="0"
                                                    Content="X"
                                                    FontSize="12"
                                                    FontFamily="Segoe UI Semibold"
                                                    Background="#F8FAFD"
                                                    Foreground="#334155"
                                                    BorderBrush="#D1D9E6"
                                                    BorderThickness="1"
                                                    Cursor="Hand"
                                                    Tag="{Binding}"
                                                    Click="RemoveUploadedImageButton_Click" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel x:Name="EmptyStatePanel"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=UploadedItemsControl, Path=HasItems}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Border Width="68"
                                Height="68"
                                Background="#E8F0FE"
                                CornerRadius="18"
                                HorizontalAlignment="Center">
                            <TextBlock Text="+"
                                       FontSize="30"
                                       Foreground="#2563EB"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Margin="0,12,0,0"
                                   Text="{loc:Loc Upload.Empty}"
                                   Foreground="#64748B"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <Button Grid.Row="4"
                    Style="{StaticResource SecondaryActionButtonStyle}"
                    Content="{loc:Loc Upload.Import}"
                    Click="ImportImagesButton_Click" />
        </Grid>
    </Border>
</UserControl>
