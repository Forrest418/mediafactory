<UserControl x:Class="Views.TaskQueueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MediaFactory.Localization">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding CurrentPageTitle}"
                       Style="{StaticResource SectionTitleStyle}"
                       FontSize="34" />
            <TextBlock Margin="0,8,0,0"
                       Text="{Binding CurrentPageDescription}"
                       Style="{StaticResource BodyTextStyle}"
                       FontSize="14" />
        </StackPanel>

        <DockPanel Grid.Row="2" LastChildFill="False">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="{loc:Loc Queue.Filter.All}" Click="AllFilterButton_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterChipButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAllFilter}" Value="True">
                                    <Setter Property="Background" Value="#DBEAFE" />
                                    <Setter Property="BorderBrush" Value="#60A5FA" />
                                    <Setter Property="Foreground" Value="#1D4ED8" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{loc:Loc Queue.Filter.Planning}" Click="PlanningFilterButton_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterChipButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlanningFilter}" Value="True">
                                    <Setter Property="Background" Value="#DCFCE7" />
                                    <Setter Property="BorderBrush" Value="#4ADE80" />
                                    <Setter Property="Foreground" Value="#15803D" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{loc:Loc Queue.Filter.Rendering}" Click="RenderingFilterButton_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterChipButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRenderingFilter}" Value="True">
                                    <Setter Property="Background" Value="#FFEDD5" />
                                    <Setter Property="BorderBrush" Value="#FB923C" />
                                    <Setter Property="Foreground" Value="#C2410C" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{loc:Loc Queue.Filter.Ready}" Click="ReadyFilterButton_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterChipButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsReadyFilter}" Value="True">
                                    <Setter Property="Background" Value="#EDE9FE" />
                                    <Setter Property="BorderBrush" Value="#A78BFA" />
                                    <Setter Property="Foreground" Value="#6D28D9" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{loc:Loc Queue.Filter.Failed}" Click="FailedFilterButton_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterChipButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFailedFilter}" Value="True">
                                    <Setter Property="Background" Value="#FEF2F2" />
                                    <Setter Property="BorderBrush" Value="#FCA5A5" />
                                    <Setter Property="Foreground" Value="#DC2626" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="{loc:Loc Queue.Filter.Completed}" Click="CompletedFilterButton_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterChipButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCompletedFilter}" Value="True">
                                    <Setter Property="Background" Value="#ECFDF5" />
                                    <Setter Property="BorderBrush" Value="#34D399" />
                                    <Setter Property="Foreground" Value="#059669" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Width="182"
                        Margin="0,0,12,0"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Content="{Binding StartSelectedQueueProjectsButtonText}"
                        IsEnabled="{Binding CanStartSelectedQueueProjects}"
                        Click="StartSelectedButton_Click" />
                <Button Width="148"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Content="{Binding RetryFilteredFailuresButtonText}"
                        IsEnabled="{Binding CanRetryFilteredFailures}"
                        Click="RetryAllFailedButton_Click" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ShellCardStyle}">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Queue.Stat.Running}" Style="{StaticResource BodyTextStyle}" FontSize="13" />
                    <TextBlock Margin="0,10,0,0" Text="{Binding RenderingProjectCount}" Style="{StaticResource SectionTitleStyle}" FontSize="32" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource ShellCardStyle}">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Queue.Stat.Planning}" Style="{StaticResource BodyTextStyle}" FontSize="13" />
                    <TextBlock Margin="0,10,0,0" Text="{Binding PlanningProjectCount}" Style="{StaticResource SectionTitleStyle}" FontSize="32" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource ShellCardStyle}">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Queue.Stat.Failed}" Style="{StaticResource BodyTextStyle}" FontSize="13" />
                    <TextBlock Margin="0,10,0,0"
                               Text="{Binding FailedProjectCount}"
                               Foreground="#DC2626"
                               Style="{StaticResource SectionTitleStyle}"
                               FontSize="32" />
                </StackPanel>
            </Border>

            <Border Grid.Column="6" Style="{StaticResource ShellCardStyle}">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Queue.Stat.Average}" Style="{StaticResource BodyTextStyle}" FontSize="13" />
                    <TextBlock Margin="0,10,0,0" Text="{Binding AverageProgressText}" Style="{StaticResource SectionTitleStyle}" FontSize="32" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="6">
            <Border Style="{StaticResource ShellCardStyle}" Padding="0">
                <DataGrid ItemsSource="{Binding FilteredTaskProjects}"
                          SelectedItem="{Binding SelectedProject, Mode=OneWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          Background="Transparent"
                          BorderThickness="0"
                          IsReadOnly="False">
                    <DataGrid.Resources>
                        <Style TargetType="TextBox">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Padding" Value="4,0" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                        </Style>
                        <Style TargetType="CheckBox">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                        </Style>
                        <Style x:Key="QueueTextElementStyle" TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                        </Style>
                        <Style x:Key="QueueTextEditingStyle" TargetType="TextBox">
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="Padding" Value="4,0" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="MinHeight" Value="54" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasRetryableFailures}" Value="True">
                                    <Setter Property="Background" Value="#FEF7F7" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="38">
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding DataContext.IsAllFilteredQueueProjectsSelected, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ToolTip="{loc:Loc Queue.SelectAllTooltip}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsQueueSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="12" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding ProgressBrush}" CornerRadius="4" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="{loc:Loc Queue.Column.Title}"
                                            Binding="{Binding ProjectName, UpdateSourceTrigger=LostFocus}"
                                            Width="1.35*"
                                            ElementStyle="{StaticResource QueueTextElementStyle}"
                                            EditingElementStyle="{StaticResource QueueTextEditingStyle}" />

                        <DataGridTextColumn Header="{loc:Loc Queue.Column.Summary}"
                                            Binding="{Binding ProjectSummary, UpdateSourceTrigger=LostFocus}"
                                            Width="1.75*"
                                            ElementStyle="{StaticResource QueueTextElementStyle}"
                                            EditingElementStyle="{StaticResource QueueTextEditingStyle}" />

                        <DataGridTextColumn Header="{loc:Loc Queue.Column.Scenario}"
                                            Binding="{Binding SelectedScenarioPresetName}"
                                            Width="110"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource QueueTextElementStyle}" />

                        <DataGridTemplateColumn Header="{loc:Loc Queue.Column.Status}" Width="126" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="10" Height="10" Fill="{Binding StageBrush}" VerticalAlignment="Center" />
                                        <TextBlock Margin="8,0,0,0"
                                                   Text="{Binding LocalizedStageText}"
                                                   Foreground="#0F172A"
                                                   FontFamily="Microsoft YaHei UI Semibold"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="{loc:Loc Queue.Column.Progress}"
                                            Binding="{Binding ProgressLabelText}"
                                            Width="70"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource QueueTextElementStyle}" />

                        <DataGridTextColumn Header="{loc:Loc Queue.Column.Scale}"
                                            Binding="{Binding SourceSummaryText}"
                                            Width="132"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource QueueTextElementStyle}" />

                        <DataGridTemplateColumn Header="{loc:Loc Queue.Column.Auto}" Width="62">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Center">
                                        <CheckBox IsChecked="{Binding AutoRenderAfterPlan, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="{loc:Loc Queue.Column.QueueStatus}"
                                            Binding="{Binding QueueRemainingText}"
                                            Width="110"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource QueueTextElementStyle}" />

                        <DataGridTemplateColumn Header="{loc:Loc Queue.Column.Run}" Width="118" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding QueueActionText}"
                                            Height="34"
                                            Padding="10,4"
                                            Background="{Binding QueueActionBackground}"
                                            BorderBrush="{Binding QueueActionBorderBrush}"
                                            Foreground="{Binding QueueActionForeground}"
                                            Tag="{Binding}"
                                            Click="TaskQueueActionButton_Click" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="{loc:Loc Queue.Column.Open}" Width="80" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{loc:Loc Queue.Open}"
                                            Width="44"
                                            Height="30"
                                            Tag="{Binding}"
                                            Click="OpenProjectButton_Click"
                                            Background="White"
                                            BorderBrush="#D7DFEB"
                                            BorderThickness="1"
                                            Foreground="#2563EB"
                                            Cursor="Hand" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="{loc:Loc Queue.Column.Close}" Width="72" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="X"
                                            Width="30"
                                            Height="30"
                                            Tag="{Binding}"
                                            Click="CloseProjectButton_Click"
                                            Background="White"
                                            BorderBrush="#D7DFEB"
                                            BorderThickness="1"
                                            Foreground="#475569"
                                            Cursor="Hand" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
