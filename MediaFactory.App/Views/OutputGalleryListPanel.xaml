<UserControl x:Class="Views.OutputGalleryListPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MediaFactory.Localization">
    <Border Style="{StaticResource ShellCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="{loc:Loc Output.Title}" Style="{StaticResource SectionTitleStyle}" FontSize="15" />
                <TextBlock Margin="0,4,0,0"
                           Text="{loc:Loc Output.Description}"
                           Style="{StaticResource BodyTextStyle}" />
            </StackPanel>

            <ListBox Grid.Row="2"
                     ItemsSource="{Binding GeneratedImages}"
                     SelectedItem="{Binding SelectedGeneratedImage, Mode=TwoWay}"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemContainerStyle="{StaticResource GalleryItemStyle}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="ThumbCard"
                                Width="164"
                                Height="194"
                                Background="White"
                                BorderBrush="#D7DFEB"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="112" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Border Background="#EEF2F7"
                                            CornerRadius="12"
                                            ClipToBounds="True"
                                            Cursor="Hand"
                                            Tag="{Binding}"
                                            MouseLeftButtonUp="PreviewImageMouseLeftButtonUp">
                                        <Image Source="{Binding Preview}" Stretch="UniformToFill" />
                                    </Border>
                                    <TextBlock x:Name="ThumbPlaceholder"
                                               Text="{loc:Loc Output.Placeholder}"
                                               Foreground="#94A3B8"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                    <StackPanel x:Name="HoverTools"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Visibility="Collapsed">
                                        <Button Width="42" Height="28" Margin="0,0,6,0" Content="{loc:Loc Output.Action.Download}" Tag="{Binding}" Click="DownloadImageButton_Click" />
                                        <Button Width="42" Height="28" Margin="0,0,6,0" Content="{loc:Loc Output.Action.Edit}" Tag="{Binding}" Click="EditImageButton_Click" />
                                        <Button Width="52" Height="28" Content="{loc:Loc Output.Action.Regenerate}" Tag="{Binding}" Click="RegenerateImageButton_Click" />
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleStyle}" FontSize="13" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Margin="0,4,0,0" Text="{Binding Description}" Foreground="#64748B" FontSize="11" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            VerticalAlignment="Bottom"
                                            Margin="10,0,0,2"
                                            Padding="8,3"
                                            Background="{Binding StatusBrush}"
                                            CornerRadius="10">
                                        <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11" />
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding HasPreview}" Value="True">
                                <Setter TargetName="ThumbPlaceholder" Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                <Setter TargetName="ThumbCard" Property="BorderBrush" Value="#3B82F6" />
                                <Setter TargetName="ThumbCard" Property="BorderThickness" Value="2" />
                                <Setter TargetName="ThumbCard" Property="Background" Value="#EFF6FF" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                <Setter TargetName="HoverTools" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</UserControl>
