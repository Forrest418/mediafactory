<UserControl x:Class="Views.ProjectLogPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MediaFactory.Localization">
    <Border Style="{StaticResource ShellCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="{loc:Loc Log.Title}" Style="{StaticResource SectionTitleStyle}" FontSize="16" />
                <TextBlock Margin="0,4,0,0"
                           Text="{Binding LogFilePath}"
                           Foreground="#2563EB"
                           FontSize="11"
                           TextWrapping="Wrap" />
            </StackPanel>

            <TextBox Grid.Row="2"
                     Style="{StaticResource EditorTextBoxStyle}"
                     Background="#0F172A"
                     BorderBrush="#1E293B"
                     Foreground="#E2E8F0"
                     FontFamily="Consolas"
                     FontSize="12"
                     IsReadOnly="True"
                     Text="{Binding RecentLogText}"
                     VerticalScrollBarVisibility="Auto" />
        </Grid>
    </Border>
</UserControl>
