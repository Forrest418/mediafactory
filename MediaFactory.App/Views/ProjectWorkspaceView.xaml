<UserControl x:Class="Views.ProjectWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MediaFactory.Localization"
             xmlns:views="clr-namespace:MediaFactory.Views">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource SoftCardStyle}"
                DataContext="{Binding SelectedProject}"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <Border Width="36" Height="36" Background="{Binding StepInputBrush}" CornerRadius="18">
                        <TextBlock Text="1" Foreground="White" FontFamily="Segoe UI Semibold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Margin="0,8,0,0" Text="{loc:Loc Workspace.Step.Import}" Foreground="#334155" FontFamily="Microsoft YaHei UI Semibold" FontSize="12" />
                </StackPanel>
                <Rectangle Grid.Column="1" Height="2" Width="60" Fill="#D8E1EE" VerticalAlignment="Center" />

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <Border Width="36" Height="36" Background="{Binding StepPlanBrush}" CornerRadius="18">
                        <TextBlock Text="2" Foreground="White" FontFamily="Segoe UI Semibold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Margin="0,8,0,0" Text="{loc:Loc Workspace.Step.Plan}" Foreground="#334155" FontFamily="Microsoft YaHei UI Semibold" FontSize="12" />
                </StackPanel>
                <Rectangle Grid.Column="3" Height="2" Width="60" Fill="#D8E1EE" VerticalAlignment="Center" />

                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                    <Border Width="36" Height="36" Background="{Binding StepRenderBrush}" CornerRadius="18">
                        <TextBlock Text="3" Foreground="White" FontFamily="Segoe UI Semibold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Margin="0,8,0,0" Text="{loc:Loc Workspace.Step.Render}" Foreground="#334155" FontFamily="Microsoft YaHei UI Semibold" FontSize="12" />
                </StackPanel>
                <Rectangle Grid.Column="5" Height="2" Width="60" Fill="#D8E1EE" VerticalAlignment="Center" />

                <StackPanel Grid.Column="6" HorizontalAlignment="Center">
                    <Border Width="36" Height="36" Background="{Binding StepReviewBrush}" CornerRadius="18">
                        <TextBlock Text="4" Foreground="White" FontFamily="Segoe UI Semibold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Margin="0,8,0,0" Text="{loc:Loc Workspace.Step.Review}" Foreground="#334155" FontFamily="Microsoft YaHei UI Semibold" FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" MinWidth="420" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="548" MinWidth="548" />
            </Grid.ColumnDefinitions>

            <views:ProjectInputPanel Grid.Column="0" DataContext="{Binding SelectedProject}" />
            <views:PlanEditorPanel Grid.Column="2" DataContext="{Binding SelectedProject}" />
            <GridSplitter Grid.Column="3"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#E2E8F0"
                          ShowsPreview="True"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />
            <views:OutputGalleryPanel Grid.Column="4" DataContext="{Binding SelectedProject}" />
        </Grid>
    </Grid>
</UserControl>
