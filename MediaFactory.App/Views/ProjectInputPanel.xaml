<UserControl x:Class="Views.ProjectInputPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MediaFactory.Views">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <views:ProjectImageUploadPanel DataContext="{Binding}" />
            <views:ProjectParameterPanel Margin="0,10,0,0"
                                         DataContext="{Binding}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
